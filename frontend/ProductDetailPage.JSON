{
    "componentName": "ProductDetailPage",
    "meta": {
        "source": "Figma: Product Detail Page (Men's Tree Runner)",
        "notes": "Navbar and footer omitted. Desktop: two-column layout (gallery left, info right). Mobile: stacked single column. Include gallery with thumbnails, selector controls, product description, details tabs, reviews, related products carousel."
    },
    "props": [
        "product",
        "relatedProducts"
    ],
    "layout": {
        "type": "container",
        "maxWidth": 1200,
        "padding": {
            "desktop": "px-8 py-8",
            "tablet": "px-6 py-6",
            "mobile": "px-4 py-4"
        },
        "backgroundColor": "#FFFFFF"
    },
    "children": [
        {
            "componentName": "Breadcrumbs",
            "props": [
                "breadcrumbs"
            ],
            "layout": {
                "type": "row",
                "gap": "2"
            },
            "styles": {
                "tailwind": "text-sm text-gray-600"
            }
        },
        {
            "componentName": "TopHeading",
            "layout": {
                "type": "column",
                "gap": "1",
                "marginBottom": "4"
            },
            "children": [
                {
                    "componentName": "ProductTitle",
                    "text": "product.title",
                    "styles": {
                        "tailwind": "text-2xl md:text-3xl font-semibold text-gray-900",
                        "role": "h1"
                    }
                },
                {
                    "componentName": "ShortBlurb",
                    "text": "product.tagline || 'Lightweight, bouncy, and wildly comfortable.'",
                    "styles": {
                        "tailwind": "text-sm text-gray-600 max-w-2xl"
                    }
                }
            ]
        },
        {
            "componentName": "MainColumns",
            "layout": {
                "type": "grid",
                "gap": "32px",
                "gridTemplate": {
                    "desktop": "grid-cols-[1fr_420px]",
                    "tablet": "grid-cols-1",
                    "mobile": "grid-cols-1"
                }
            },
            "children": [
                {
                    "componentName": "GalleryColumn",
                    "layout": {
                        "type": "column",
                        "gap": "4"
                    },
                    "children": [
                        {
                            "componentName": "ImageGallery",
                            "props": [
                                "product.images"
                            ],
                            "layout": {
                                "type": "column",
                                "gap": "3"
                            },
                            "styles": {
                                "tailwind": "rounded-md overflow-hidden"
                            },
                            "children": [
                                {
                                    "componentName": "MainImage",
                                    "type": "image",
                                    "props": {
                                        "src": "product.images[activeIndex].url",
                                        "alt": "product.title + ' image ' + activeIndex"
                                    },
                                    "styles": {
                                        "tailwind": "w-full aspect-[4/3] object-cover rounded-md",
                                        "behavior": "click to open lightbox, pinch/zoom on mobile"
                                    }
                                },
                                {
                                    "componentName": "ThumbnailStrip",
                                    "type": "row",
                                    "layout": {
                                        "overflow": "auto",
                                        "gap": "2"
                                    },
                                    "styles": {
                                        "tailwind": "mt-3 gap-2"
                                    },
                                    "behavior": "click thumbnail => set activeIndex",
                                    "props": [
                                        "product.images"
                                    ]
                                }
                            ]
                        },
                        {
                            "componentName": "TrustBadges",
                            "layout": {
                                "type": "row",
                                "gap": "3",
                                "marginTop": "4"
                            },
                            "children": [
                                {
                                    "componentName": "ShippingBadge",
                                    "text": "Free Shipping on orders over $75",
                                    "styles": {
                                        "tailwind": "text-sm text-gray-600"
                                    }
                                },
                                {
                                    "componentName": "ReturnsBadge",
                                    "text": "Easy Returns",
                                    "styles": {
                                        "tailwind": "text-sm text-gray-600"
                                    }
                                }
                            ]
                        },
                        {
                            "componentName": "ProductHighlights",
                            "layout": {
                                "type": "row",
                                "gap": "3",
                                "marginTop": "4"
                            },
                            "children": [
                                {
                                    "componentName": "Feature1",
                                    "text": "BREATHABLE — Tree Knit keeps feet cool",
                                    "styles": {
                                        "tailwind": "text-sm text-gray-700"
                                    }
                                },
                                {
                                    "componentName": "Feature2",
                                    "text": "LIGHTWEIGHT — Flexible & functional",
                                    "styles": {
                                        "tailwind": "text-sm text-gray-700"
                                    }
                                },
                                {
                                    "componentName": "Feature3",
                                    "text": "SUSTAINABLE — TENCEL™ Lyocell upper",
                                    "styles": {
                                        "tailwind": "text-sm text-gray-700"
                                    }
                                }
                            ]
                        }
                    ]
                },
                {
                    "componentName": "InfoColumn",
                    "layout": {
                        "type": "column",
                        "gap": "4"
                    },
                    "styles": {
                        "tailwind": "pt-2"
                    },
                    "children": [
                        {
                            "componentName": "MetaRow",
                            "layout": {
                                "type": "row",
                                "align": "center",
                                "gap": "3"
                            },
                            "children": [
                                {
                                    "componentName": "Price",
                                    "text": "product.priceFormatted",
                                    "styles": {
                                        "tailwind": "text-2xl font-semibold text-gray-900"
                                    }
                                },
                                {
                                    "componentName": "RatingSummary",
                                    "type": "rating",
                                    "value": "product.rating",
                                    "metaText": "product.reviewsCount + ' Reviews'",
                                    "styles": {
                                        "tailwind": "text-sm text-gray-600"
                                    }
                                }
                            ]
                        },
                        {
                            "componentName": "Badges",
                            "layout": {
                                "type": "row",
                                "gap": "2"
                            },
                            "children": [
                                {
                                    "componentName": "BestsellerBadge",
                                    "condition": "product.isBestseller",
                                    "type": "pill",
                                    "text": "BESTSELLER",
                                    "styles": {
                                        "tailwind": "bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded-full"
                                    }
                                },
                                {
                                    "componentName": "LimitedBadge",
                                    "condition": "product.isLimited",
                                    "type": "pill",
                                    "text": "LIMITED",
                                    "styles": {
                                        "tailwind": "bg-beige-muted text-gray-800 text-xs px-2 py-1 rounded-full"
                                    }
                                }
                            ]
                        },
                        {
                            "componentName": "VariantSelectors",
                            "layout": {
                                "type": "column",
                                "gap": "3"
                            },
                            "children": [
                                {
                                    "componentName": "ColorSwatches",
                                    "props": [
                                        "product.colors"
                                    ],
                                    "type": "swatches",
                                    "styles": {
                                        "tailwind": "flex gap-2 items-center"
                                    },
                                    "behavior": "click swatch => change active image/color"
                                },
                                {
                                    "componentName": "SizeSelector",
                                    "props": [
                                        "product.sizes"
                                    ],
                                    "type": "selector",
                                    "layout": {
                                        "type": "row",
                                        "wrap": true,
                                        "gap": "2"
                                    },
                                    "styles": {
                                        "tailwind": "text-sm"
                                    },
                                    "behavior": "show size availability; unavailable sizes disabled; show size guide modal on link click"
                                },
                                {
                                    "componentName": "QuantityAndCTA",
                                    "layout": {
                                        "type": "row",
                                        "gap": "3",
                                        "align": "center"
                                    },
                                    "children": [
                                        {
                                            "componentName": "QuantitySelector",
                                            "type": "stepper",
                                            "default": 1,
                                            "styles": {
                                                "tailwind": "w-24"
                                            }
                                        },
                                        {
                                            "componentName": "AddToCartButton",
                                            "type": "button",
                                            "text": "Add to cart",
                                            "styles": {
                                                "tailwind": "flex-1 py-3 rounded-full bg-black text-white font-medium text-sm"
                                            },
                                            "behavior": "disabled if no size selected"
                                        },
                                        {
                                            "componentName": "WishlistButton",
                                            "type": "icon-button",
                                            "ariaLabel": "Add to wishlist"
                                        }
                                    ]
                                },
                                {
                                    "componentName": "ShippingAndReturns",
                                    "layout": {
                                        "type": "column",
                                        "gap": "1"
                                    },
                                    "children": [
                                        {
                                            "componentName": "ShippingText",
                                            "text": "Free Shipping On Orders Over $75. Easy Returns",
                                            "styles": {
                                                "tailwind": "text-sm text-gray-600"
                                            }
                                        },
                                        {
                                            "componentName": "SupportLinks",
                                            "type": "row",
                                            "gap": "3",
                                            "children": [
                                                {
                                                    "componentName": "LiveChat",
                                                    "type": "link",
                                                    "text": "Live Chat"
                                                },
                                                {
                                                    "componentName": "HelpEmail",
                                                    "type": "link",
                                                    "text": "help@allbirds.com"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "componentName": "SecondaryActions",
                            "layout": {
                                "type": "row",
                                "gap": "2"
                            },
                            "children": [
                                {
                                    "componentName": "ShareButton",
                                    "type": "icon-button",
                                    "ariaLabel": "Share product"
                                },
                                {
                                    "componentName": "CompareButton",
                                    "type": "button",
                                    "text": "Compare",
                                    "styles": {
                                        "tailwind": "px-3 py-2 border rounded-md text-sm"
                                    }
                                }
                            ]
                        },
                        {
                            "componentName": "DetailsTabs",
                            "type": "tabs",
                            "props": [
                                "product"
                            ],
                            "tabs": [
                                {
                                    "tabName": "The details",
                                    "component": {
                                        "componentName": "DetailsTab",
                                        "children": [
                                            {
                                                "componentName": "Description",
                                                "text": "product.descriptionParagraphs",
                                                "styles": {
                                                    "tailwind": "text-sm text-gray-700 leading-relaxed"
                                                }
                                            },
                                            {
                                                "componentName": "WashCare",
                                                "title": "Wash & Care",
                                                "text": "product.washCare || 'Machine-washable. Remove insoles & laces.'",
                                                "styles": {
                                                    "tailwind": "mt-4 text-sm text-gray-700"
                                                }
                                            }
                                        ]
                                    }
                                },
                                {
                                    "tabName": "Materials",
                                    "component": {
                                        "componentName": "MaterialsTab",
                                        "children": [
                                            {
                                                "componentName": "MaterialsText",
                                                "text": "product.materials || 'TENCEL™ Lyocell upper, sugarcane SweetFoam™ midsole.'",
                                                "styles": {
                                                    "tailwind": "text-sm text-gray-700"
                                                }
                                            },
                                            {
                                                "componentName": "SustainabilityCallout",
                                                "text": "Short bullet points about sustainability",
                                                "styles": {
                                                    "tailwind": "mt-3 text-sm text-gray-600"
                                                }
                                            }
                                        ]
                                    }
                                },
                                {
                                    "tabName": "Reviews",
                                    "component": {
                                        "componentName": "ReviewsTab",
                                        "children": [
                                            {
                                                "componentName": "ReviewSummary",
                                                "layout": {
                                                    "type": "row",
                                                    "gap": "4",
                                                    "align": "center"
                                                },
                                                "children": [
                                                    {
                                                        "componentName": "AvgRatingBig",
                                                        "text": "product.rating",
                                                        "styles": {
                                                            "tailwind": "text-3xl font-bold"
                                                        }
                                                    },
                                                    {
                                                        "componentName": "RatingHistogram",
                                                        "type": "histogram",
                                                        "data": "product.ratingDistribution",
                                                        "styles": {
                                                            "tailwind": "text-sm"
                                                        }
                                                    }
                                                ]
                                            },
                                            {
                                                "componentName": "ReviewList",
                                                "type": "list",
                                                "repeatFor": "product.reviews",
                                                "limit": 6,
                                                "childComponent": {
                                                    "componentName": "ReviewCard",
                                                    "children": [
                                                        {
                                                            "componentName": "ReviewerMeta",
                                                            "text": "review.author + ' • ' + review.date",
                                                            "styles": {
                                                                "tailwind": "text-sm font-medium"
                                                            }
                                                        },
                                                        {
                                                            "componentName": "ReviewRating",
                                                            "type": "rating",
                                                            "value": "review.rating"
                                                        },
                                                        {
                                                            "componentName": "ReviewText",
                                                            "text": "review.body",
                                                            "styles": {
                                                                "tailwind": "text-sm text-gray-700"
                                                            }
                                                        }
                                                    ]
                                                }
                                            },
                                            {
                                                "componentName": "LoadMoreReviews",
                                                "type": "button",
                                                "text": "Load more reviews",
                                                "styles": {
                                                    "tailwind": "mt-4 px-4 py-2 border rounded-md"
                                                }
                                            }
                                        ]
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "componentName": "RelatedProducts",
            "layout": {
                "type": "column",
                "gap": "4",
                "marginTop": "8"
            },
            "children": [
                {
                    "componentName": "SectionTitle",
                    "text": "You may also like",
                    "styles": {
                        "tailwind": "text-lg font-semibold text-gray-900"
                    }
                },
                {
                    "componentName": "RelatedCarousel",
                    "props": [
                        "relatedProducts"
                    ],
                    "layout": {
                        "type": "carousel",
                        "visibleItems": {
                            "desktop": 4,
                            "tablet": 2,
                            "mobile": 1
                        },
                        "gap": "4"
                    },
                    "childComponentRef": "ProductCard"
                }
            ]
        },
        {
            "componentName": "FooterCTAs",
            "layout": {
                "type": "row",
                "gap": "6",
                "marginTop": "8"
            },
            "children": [
                {
                    "componentName": "SubscribeCTA",
                    "text": "Sign up for updates",
                    "styles": {
                        "tailwind": "flex-1"
                    }
                },
                {
                    "componentName": "HelpCTA",
                    "text": "Need help? Live chat or call us",
                    "styles": {
                        "tailwind": "flex-1"
                    }
                }
            ]
        }
    ],
    "designSystem": {
        "colors": {
            "page-bg": "#ffffff",
            "muted": "#6b7280",
            "text": "#111827",
            "accent": "#111827",
            "beige-muted": "#f3efe9",
            "success": "#10b981"
        },
        "typography": {
            "fontFamily": "Inter, system-ui, -apple-system, 'Segoe UI', Roboto",
            "sizes": {
                "sm": "14px",
                "base": "16px",
                "lg": "18px",
                "xl": "20px",
                "2xl": "28px"
            },
            "weights": {
                "regular": 400,
                "medium": 500,
                "semibold": 600,
                "bold": 700
            }
        },
        "spacing": {
            "xs": "4px",
            "sm": "8px",
            "md": "16px",
            "lg": "24px",
            "xl": "32px"
        },
        "radius": {
            "sm": "6px",
            "md": "12px",
            "lg": "16px"
        },
        "shadows": {
            "sm": "0 1px 3px rgba(0,0,0,0.06)",
            "md": "0 8px 24px rgba(0,0,0,0.08)"
        },
        "breakpoints": {
            "mobile": "0-639px",
            "tablet": "640-1023px",
            "desktop": "1024px+"
        }
    },
    "behaviorNotes": {
        "gallery": "main image opens lightbox on click; support keyboard navigation and swiping; thumbnails horizontally scroll on small screens",
        "sizeSelector": "show 'What's my size' tooltip; disable Add to Cart until size selected",
        "addToCart": "on click, animate mini-cart flyout from Add button to cart icon; show success toast",
        "tabs": "use aria-controls and role=tablist; preserve tab state in URL hash",
        "reviews": "support filtering by 'With media' and 'Verified buyer'; paginate or lazy-load"
    },
    "accessibility": {
        "notes": [
            "All interactive elements must have accessible labels (aria-label).",
            "Images must include descriptive alt text (product color + angle).",
            "Color swatches require text alternatives (aria-label) for screen readers.",
            "Modal/dialogs (lightbox, size guide) must trap focus and restore on close.",
            "Keyboard: ensure focus visible for all interactive controls; thumbnails and swatches navigable by arrow keys."
        ]
    },
    "tailwindHints": {
        "container": "max-w-[1200px] mx-auto px-8",
        "columns": "lg:grid-cols-[1fr_420px] gap-8",
        "mainImage": "w-full aspect-[4/3] object-cover rounded-md",
        "thumbnail": "w-20 h-20 rounded-md object-cover ring-2 ring-transparent hover:ring-accent",
        "ctaPrimary": "bg-black text-white rounded-full py-3 px-5 font-medium",
        "badge": "bg-gray-100 text-xs rounded-full px-2 py-1"
    },
    "finalImportStructure": {
        "ProductDetailPage": [
            "Breadcrumbs",
            "TopHeading",
            "GalleryColumn",
            "InfoColumn",
            "DetailsTabs",
            "RelatedProducts"
        ],
        "GalleryColumn": [
            "ImageGallery",
            "TrustBadges",
            "ProductHighlights"
        ],
        "InfoColumn": [
            "MetaRow",
            "VariantSelectors",
            "DetailsTabs"
        ]
    }
}