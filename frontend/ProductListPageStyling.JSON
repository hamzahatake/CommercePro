{
  "componentName": "ProductListPage",
  "meta": {
    "source": "Figma: Product List Page (Men's Shoes)",
    "notes": "Navbar is global and omitted. Footer ignored. Page contains a breadcrumb, page heading + subtitle, a filter control row, and a responsive product grid with a promotional hero tile."
  },
  "layout": {
    "type": "container",
    "maxWidth": 1200,
    "padding": { "desktop": "px-8 py-8", "tablet": "px-6 py-6", "mobile": "px-4 py-4" },
    "backgroundColor": "#f5f2ee"
  },
  "children": [
    {
      "componentName": "Breadcrumbs",
      "layout": { "type": "row", "align": "center", "gap": "2" },
      "styles": { "text": "text-sm text-gray-600" },
      "content": ["Home", " / ", "Men", " / ", "Men's Shoes"]
    },
    {
      "componentName": "PageHeader",
      "layout": { "type": "column", "gap": "2", "marginTop": "4" },
      "children": [
        {
          "componentName": "Title",
          "text": "Men's Shoes",
          "styles": {
            "tailwind": "text-2xl md:text-3xl font-semibold text-gray-900",
            "accessibility": "role=h1"
          }
        },
        {
          "componentName": "Subtitle",
          "text": "The world’s most comfortable sneakers — for everyday adventures.",
          "styles": { "tailwind": "mt-1 text-sm text-gray-600 max-w-2xl" }
        }
      ]
    },
    {
      "componentName": "FilterRow",
      "purpose": "Primary filtering controls for responsive / mobile-first UI",
      "layout": {
        "type": "row",
        "justify": "between",
        "align": "center",
        "gap": "4",
        "marginTop": "6",
        "responsive": {
          "desktop": "row (left: left controls, right: sort + view toggles)",
          "mobile": "stack (collapsible)"
        }
      },
      "styles": {
        "container": "bg-white rounded-full shadow-sm p-2 flex items-center",
        "height": "h-12"
      },
      "children": [
        {
          "componentName": "FilterToggleButton",
          "type": "button",
          "aria": { "expanded": false },
          "icon": "filter",
          "label": "FILTER",
          "styles": {
            "tailwind": "px-4 py-2 rounded-full border border-gray-200 text-sm font-medium",
            "states": {
              "active": "bg-gray-100",
              "hover": "shadow-sm"
            }
          },
          "behavior": "opens FilterPanel (sidebar on desktop, drawer on mobile)"
        },
        {
          "componentName": "FilterSummary",
          "type": "text",
          "text": "All products (132)",
          "styles": { "tailwind": "text-sm text-gray-600 ml-3" }
        },
        {
          "componentName": "RightControls",
          "layout": { "type": "row", "gap": "2", "mlAuto": true },
          "children": [
            {
              "componentName": "SortSelect",
              "type": "select",
              "options": ["Featured", "Best selling", "Price: Low → High", "Price: High → Low", "Newest"],
              "styles": { "tailwind": "text-sm rounded-full border border-gray-200 px-3 py-2" }
            },
            {
              "componentName": "ViewToggle",
              "type": "segmented-control",
              "options": ["grid", "list"],
              "default": "grid",
              "styles": { "tailwind": "rounded-full border border-gray-200 p-1" }
            }
          ]
        }
      ]
    },
    {
      "componentName": "MainGrid",
      "layout": {
        "type": "grid",
        "gap": "24px",
        "gridTemplate": {
          "desktop": "grid-cols-4 auto-rows-min",
          "tablet": "grid-cols-2",
          "mobile": "grid-cols-1"
        },
        "notes": "On desktop, leftmost column can become a sticky FilterPanel if desired."
      },
      "children": [
        {
          "componentName": "FilterPanel",
          "variant": "sidebar",
          "placement": "left",
          "layout": { "type": "column", "gap": "4" },
          "styles": {
            "tailwind": "bg-white rounded-lg p-5 shadow-sm",
            "width": "w-72",
            "sticky": "top-24"
          },
          "children": [
            {
              "componentName": "FilterHeader",
              "layout": { "type": "row", "justify": "between", "align": "center" },
              "children": [
                { "componentName": "Label", "text": "Filters", "styles": { "tailwind": "font-semibold text-gray-800" } },
                { "componentName": "ClearAll", "type": "button", "text": "Clear", "styles": { "tailwind": "text-sm text-gray-500" } }
              ]
            },
            {
              "componentName": "CategoryFilter",
              "type": "checkboxList",
              "title": "Categories",
              "options": ["Sneakers", "Casual", "Running", "Slip-on", "Boots"],
              "styles": { "tailwind": "text-sm" }
            },
            {
              "componentName": "PriceFilter",
              "type": "range",
              "title": "Price",
              "min": 0,
              "max": 500,
              "default": [40, 220],
              "uiHint": "two-handled slider with numeric inputs for precise min/max"
            },
            {
              "componentName": "ColorFilter",
              "type": "swatches",
              "title": "Color",
              "options": [
                { "color": "#FFFFFF", "label": "White" },
                { "color": "#111827", "label": "Black" },
                { "color": "#E11D48", "label": "Red" },
                { "color": "#F59E0B", "label": "Tan" }
              ],
              "styles": { "tailwind": "flex gap-2" }
            },
            {
              "componentName": "BrandFilter",
              "type": "checkboxList",
              "title": "Brand",
              "options": ["Allbirds", "Nike", "Adidas", "Vans", "New Balance"],
              "styles": { "tailwind": "text-sm" }
            },
            {
              "componentName": "RatingFilter",
              "type": "radioOrCheckbox",
              "title": "Rating",
              "options": ["4★ & up", "3★ & up", "2★ & up"],
              "styles": { "tailwind": "text-sm" }
            },
            {
              "componentName": "AvailabilitySwitch",
              "type": "toggle",
              "title": "In stock only",
              "default": true
            },
            {
              "componentName": "ApplyFiltersButton",
              "type": "button",
              "text": "Apply filters",
              "styles": { "tailwind": "w-full py-2 rounded-full bg-black text-white font-medium" }
            }
          ]
        },
        {
          "componentName": "ProductGridContent",
          "layout": {
            "type": "grid",
            "gap": "20px",
            "gridTemplate": {
              "desktop": "repeat(3, minmax(0, 1fr)) / with promo tile occupying 2 cols in row 1",
              "tablet": "grid-cols-2",
              "mobile": "grid-cols-1"
            }
          },
          "children": [
            {
              "componentName": "PromoTile",
              "purpose": "Large marketing tile inside grid (seen top-right in Figma)",
              "layout": { "desktopSpanCols": 2, "height": "h-64", "align": "center" },
              "styles": {
                "tailwind": "rounded-lg overflow-hidden relative",
                "backgroundImageHint": "use high-res hero image with text overlay",
                "overlay": "linear-gradient(to bottom, rgba(0,0,0,0.15), rgba(0,0,0,0.25))"
              },
              "children": [
                { "componentName": "PromoHeadline", "text": "Bold color. Big comfort.", "styles": { "tailwind": "text-white text-2xl font-bold" } },
                { "componentName": "PromoCTA", "type": "button", "text": "Shop Now", "styles": { "tailwind": "mt-4 inline-block py-2 px-4 rounded-full bg-white text-black" } }
              ]
            },
            {
              "componentName": "ProductsListLoop",
              "type": "repeat",
              "repeatFor": "products[]",
              "limit": 48,
              "childComponent": {
                "componentName": "ProductCard",
                "layout": { "type": "card", "direction": "column", "gap": "3" },
                "styles": {
                  "tailwind": "bg-white rounded-xl p-4 shadow-sm border border-transparent hover:shadow-md transform hover:-translate-y-1 transition",
                  "imageContainer": "aspect-w-1 aspect-h-1 w-full rounded-md overflow-hidden bg-gray-50"
                },
                "children": [
                  {
                    "componentName": "BadgesRow",
                    "type": "row",
                    "layout": { "justify": "between" },
                    "children": [
                      { "componentName": "BadgeLeft", "condition": "product.tag", "type": "pill", "variants": ["NEW","BESTSELLER","LOW STOCK"], "styles": "text-xs rounded-full px-2 py-1 bg-gray-100 text-gray-700" },
                      { "componentName": "WishlistIcon", "type": "icon-button", "ariaLabel": "Add to wishlist" }
                    ]
                  },
                  {
                    "componentName": "ImageBlock",
                    "type": "image",
                    "props": {
                      "src": "product.main_image",
                      "alt": "product.title",
                      "objectFit": "cover",
                      "loading": "lazy"
                    },
                    "styles": { "tailwind": "w-full h-40 md:h-44 object-cover rounded-md" }
                  },
                  {
                    "componentName": "TitleRow",
                    "layout": { "type": "column", "gap": "1" },
                    "children": [
                      { "componentName": "ProductTitle", "text": "product.title", "styles": { "tailwind": "text-sm font-medium text-gray-900 truncate", "maxLines": 2 } },
                      { "componentName": "ColorSwatches", "type": "inline-swatches", "value": "product.available_colors", "ui": "small dots with tooltips" }
                    ]
                  },
                  {
                    "componentName": "PriceAndRating",
                    "layout": { "type": "row", "justify": "between", "align": "center" },
                    "children": [
                      { "componentName": "PriceBlock", "text": "product.price", "styles": { "tailwind": "text-base font-semibold text-gray-900" }, "variants": { "onSale": { "text": "salePrice", "strikeThrough": "originalPrice" } } },
                      { "componentName": "RatingMini", "type": "rating", "value": "product.rating", "styles": "text-sm" }
                    ]
                  },
                  {
                    "componentName": "AddToCart",
                    "type": "button",
                    "text": "Add to cart",
                    "styles": {
                      "tailwind": "mt-2 w-full py-2 rounded-full border border-gray-200 text-sm font-medium",
                      "states": { "hover": "bg-gray-50", "disabled": "opacity-50 cursor-not-allowed" }
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "componentName": "PaginationRow",
      "layout": { "type": "row", "justify": "center", "marginTop": "6" },
      "children": [
        { "componentName": "Prev", "type": "button", "styles": "px-3 py-2 rounded-md border" },
        { "componentName": "PageNumbers", "type": "list", "styles": "mx-4" },
        { "componentName": "Next", "type": "button", "styles": "px-3 py-2 rounded-md border" }
      ]
    }
  ],
  "designSystem": {
    "colors": {
      "page-bg": "#f5f2ee",
      "surface": "#ffffff",
      "muted": "#6b7280",
      "text": "#111827",
      "accent": "#111827",
      "beige-muted": "#ece8e2",
      "footer-bg": "#1f1f1f"
    },
    "typography": {
      "fontFamily": "Inter, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial",
      "sizes": { "xs": "12px", "sm": "14px", "base": "16px", "lg": "18px", "xl": "20px", "2xl": "28px" },
      "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
    },
    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px"
    },
    "radius": { "sm": "6px", "md": "12px", "lg": "16px", "pill": "9999px" },
    "shadows": {
      "sm": "0 1px 3px rgba(0,0,0,0.06)",
      "md": "0 6px 18px rgba(0,0,0,0.08)"
    },
    "breakpoints": {
      "mobile": "0-639px (sm)",
      "tablet": "640-1023px (md)",
      "desktop": "1024px+ (lg)"
    }
  },
  "accessibility": {
    "notes": [
      "All interactive controls must have accessible labels (aria-label).",
      "Images must include alt text.",
      "Filter drawers should trap focus when open on mobile.",
      "Buttons should have 3:1 contrast on small text; CTAs 4.5:1."
    ]
  },
  "tailwindHints": {
    "container": "max-w-[1200px] mx-auto px-8",
    "page-bg": "bg-[#f5f2ee]",
    "card": "bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-transform",
    "promo": "col-span-2 md:col-span-2 row-span-1 rounded-lg overflow-hidden",
    "filterSidebar": "w-72 sticky top-24 bg-white rounded-lg p-5 shadow-sm"
  },
  "finalImportStructure": {
    "ProductListPage": ["Breadcrumbs", "PageHeader", "FilterRow", "MainGrid", "PaginationRow"],
    "MainGrid": ["FilterPanel", "ProductGridContent", "PromoTile", "ProductsListLoop"],
    "ProductCard": ["BadgesRow", "ImageBlock", "TitleRow", "PriceAndRating", "AddToCart"]
  }
}
